Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{"analysis", " ", "parameters", " ", "to", " ", "be", " ", "set"}], 
   "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"DROPLEFT", "=", "5"}], ";"}], 
   RowBox[{"(*", 
    RowBox[{
    "pixels", " ", "to", " ", "the", " ", "left", " ", "of", " ", "each", " ",
      "position", " ", "to", " ", "be", " ", "disregarded"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"DROPRIGHT", "=", "20"}], ";"}], 
   RowBox[{"(*", 
    RowBox[{
    "pixels", " ", "to", " ", "the", " ", "right", " ", "of", " ", "each", " ",
      "position", " ", "to", " ", "be", " ", "disregarded"}], "*)"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"analyze", " ", "line", " ", 
     RowBox[{"profiles", ":", " ", 
      RowBox[{"find", " ", "minima"}]}]}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"POS", "=", 
     RowBox[{"{", "initialPosition", "}"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Map", "[", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"Function", "[", 
       RowBox[{"profile", ",", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"dropLeft", "=", 
          RowBox[{
           RowBox[{"POS", "[", 
            RowBox[{"[", 
             RowBox[{"-", "1"}], "]"}], "]"}], "-", "DROPLEFT"}]}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{"dropRight", "=", 
          RowBox[{
           RowBox[{"Length", "@", "profile"}], "-", 
           RowBox[{"POS", "[", 
            RowBox[{"[", 
             RowBox[{"-", "1"}], "]"}], "]"}], "-", "DROPRIGHT"}]}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{"dropProfile", "=", 
          RowBox[{"Drop", "[", 
           RowBox[{"profile", ",", "dropLeft"}], "]"}]}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{"dropProfile", "=", 
          RowBox[{"Drop", "[", 
           RowBox[{"dropProfile", ",", 
            RowBox[{"-", "dropRight"}]}], "]"}]}], ";", "\[IndentingNewLine]", 
         RowBox[{"smallestPositions", "=", 
          RowBox[{"PositionSmallest", "[", 
           RowBox[{"dropProfile", ",", "3"}], "]"}]}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{"nearest", "=", 
          RowBox[{"First", "[", 
           RowBox[{"Nearest", "[", 
            RowBox[{
             RowBox[{"Flatten", "[", "smallestPositions", "]"}], ",", 
             RowBox[{"POS", "[", 
              RowBox[{"[", 
               RowBox[{"-", "1"}], "]"}], "]"}]}], "]"}], "]"}]}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{"AppendTo", "[", 
          RowBox[{"POS", ",", 
           RowBox[{"nearest", "+", "dropLeft"}]}], "]"}], ";"}]}], 
       "\[IndentingNewLine]", "]"}], ",", 
      RowBox[{"profiles", "[", 
       RowBox[{"[", 
        RowBox[{"1", ";;"}], "]"}], "]"}]}], "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"DROPLEFT", "=", "0"}], ";", 
    RowBox[{"DROPRIGHT", "=", "0"}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"POS", "=", 
     RowBox[{"(", 
      RowBox[{"POS", "-", 
       RowBox[{"POS", "[", 
        RowBox[{"[", "1", "]"}], "]"}]}], ")"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"time", "=", 
     RowBox[{
      RowBox[{"Range", "[", 
       RowBox[{"0.", ",", 
        RowBox[{
         RowBox[{"Length", "@", "POS"}], "-", "1"}]}], "]"}], "/", "FPS"}]}], 
    ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"ListLinePlot", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"{", 
       RowBox[{"time", ",", "POS"}], "}"}], "\[Transpose]"}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{"FrameLabel", "->", 
      RowBox[{"{", 
       RowBox[{"\"\<time (s)\>\"", ",", "\"\<position (px)\>\""}], "}"}]}], ",", 
     RowBox[{"PlotStyle", "->", "Red"}], ",", "STYLE"}], "]"}]}]}]], "Input",
