Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{"Analytical", " ", 
    RowBox[{"(", "Lambert", ")"}], " ", "fitting", " ", "procedure"}], "*)"}],
   "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{"derived", " ", "parameters"}], "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"Vt", "=", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"time", ",", "V"}], "}"}], "\[Transpose]"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Vt", "=", 
     RowBox[{"Join", "[", 
      RowBox[{"Vt", ",", 
       RowBox[{
        RowBox[{
         RowBox[{"{", 
          RowBox[{
           RowBox[{
            RowBox[{"#", "*", 
             RowBox[{"(", 
              RowBox[{
               RowBox[{"Differences", "[", "time", "]"}], "[", 
               RowBox[{"[", "1", "]"}], "]"}], ")"}]}], "+", 
            RowBox[{"time", "[", 
             RowBox[{"[", 
              RowBox[{"-", "1"}], "]"}], "]"}]}], ",", 
           RowBox[{"Mean", "[", 
            RowBox[{"V", "[", 
             RowBox[{"[", 
              RowBox[{
               RowBox[{"-", "5"}], ";;", 
               RowBox[{"-", "1"}]}], "]"}], "]"}], "]"}]}], "}"}], "&"}], "/@", 
        RowBox[{"Range", "[", "500", "]"}]}]}], "]"}]}], ";"}], 
   RowBox[{"(*", 
    RowBox[{
    "some", " ", "padding", " ", "at", " ", "the", " ", "end", " ", "to", " ",
      "the", " ", "the", " ", "Lambert", " ", "fit", " ", "to", " ", 
     "converge"}], "*)"}], "\n", 
   RowBox[{
    RowBox[{"V0", "=", 
     RowBox[{"Vt", "[", 
      RowBox[{"[", 
       RowBox[{"1", ",", "2"}], "]"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"A0", "=", 
     RowBox[{"4", "*", "Pi", "*", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"DV", "/", "2"}], ")"}], "^", "2"}]}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{"Lambert", "/", "analytical"}], " ", "fit"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"ClearAll", "[", "LambertV", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"LambertV", "[", 
      RowBox[{
      "t_", ",", "cin_", ",", "cout_", ",", "v0_", ",", "a0_", ",", "Pf_"}], 
      "]"}], ":=", 
     FractionBox[
      RowBox[{"cin", " ", "v0", " ", 
       RowBox[{"(", 
        RowBox[{"1", "+", 
         RowBox[{"ProductLog", "[", 
          FractionBox[
           RowBox[{
            RowBox[{"(", 
             RowBox[{
              RowBox[{"-", "cin"}], "+", "cout"}], ")"}], " ", 
            SuperscriptBox["\[ExponentialE]", 
             RowBox[{
              RowBox[{"-", "1"}], "+", 
              FractionBox[
               RowBox[{"cout", " ", 
                RowBox[{"(", 
                 RowBox[{"v0", "-", 
                  RowBox[{
                  "a0", " ", "cout", " ", "Pf", " ", "t", " ", "VW"}]}], 
                 ")"}]}], 
               RowBox[{"cin", " ", "v0"}]]}]]}], "cin"], "]"}]}], ")"}]}], 
      "cout"]}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"LambertFit", "=", 
     RowBox[{"NonlinearModelFit", "[", 
      RowBox[{"Vt", ",", "\[IndentingNewLine]", 
       RowBox[{"LambertV", "[", 
        RowBox[{
        "t", ",", "CIN", ",", "cout", ",", "V0", ",", "A0", ",", "Pf"}], 
