    RowBox[{"DSolve", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"eqD", ",", 
        RowBox[{
         RowBox[{"V", "[", "0", "]"}], "==", "V0"}]}], "}"}], ",", 
      RowBox[{"V", "[", "t", "]"}], ",", "t"}], "]"}], "//", "FullSimplify"}],
    "//", "Quiet"}], ";"}], "\[IndentingNewLine]", 
