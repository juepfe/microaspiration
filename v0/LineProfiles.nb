Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{"exponential", " ", "fitting", " ", "procedure"}], "*)"}], 
  "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"ClearAll", "[", 
     RowBox[{"fExp", ",", "T"}], "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{
      RowBox[{"fExp", "[", 
       RowBox[{"t_", ",", "\[Tau]_", ",", "a_", ",", "b_", ",", "t0_"}], 
       "]"}], "=", 
      RowBox[{"Piecewise", "[", 
       RowBox[{"{", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"0", ",", 
           RowBox[{"t", "<", "t0"}]}], "}"}], ",", "\[IndentingNewLine]", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"b", "*", 
            RowBox[{"(", 
             RowBox[{"1", "-", 
              RowBox[{"Exp", "[", 
               RowBox[{
                RowBox[{"-", 
                 RowBox[{"(", 
                  RowBox[{"t", "-", "t0"}], ")"}]}], "/", "\[Tau]"}], "]"}]}],
              ")"}]}], ",", 
           RowBox[{"t", ">=", "t0"}]}], "}"}]}], "\[IndentingNewLine]", "}"}],
        "]"}]}], ";"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"fExp", "[", 
     RowBox[{"t_", ",", "\[Tau]_", ",", "a_", ",", "o_"}], "]"}], ":=", 
    RowBox[{
     RowBox[{"a", "*", 
      RowBox[{"(", 
       RowBox[{"1", "-", 
        RowBox[{"Exp", "[", 
         RowBox[{
          RowBox[{"-", "t"}], "/", "\[Tau]"}], "]"}]}], ")"}]}], "+", "o"}]}],
    "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"expFit", "=", 
     RowBox[{"NonlinearModelFit", "[", 
      RowBox[{"Vt", ",", 
       RowBox[{"(*", 
        RowBox[{"Table", "[", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{"t", ",", 
            RowBox[{
             RowBox[{"Interpolation", "[", 
              RowBox[{"Vt", ",", 
               RowBox[{"InterpolationOrder", "->", "1"}]}], "]"}], "[", "t", 
             "]"}]}], "}"}], ",", 
          RowBox[{"{", 
           RowBox[{"t", ",", 
            RowBox[{"time", "[", 
             RowBox[{"[", "1", "]"}], "]"}], ",", 
            RowBox[{"time", "[", 
             RowBox[{"[", 
              RowBox[{"-", "1"}], "]"}], "]"}], ",", "0.01"}], "}"}]}], "]"}],
         "*)"}], "\[IndentingNewLine]", 
       RowBox[{"fExp", "[", 
        RowBox[{"t", ",", "\[Tau]", ",", "a", ",", "o"}], "]"}], ",", 
       "\[IndentingNewLine]", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"\[Tau]", ",", "10."}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"a", ",", "10."}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"o", ",", 
           RowBox[{"Vt", "[", 
            RowBox[{"[", 
             RowBox[{"1", ",", "2"}], "]"}], "]"}]}], "}"}]}], "}"}], ",", 
       "\[IndentingNewLine]", "t", ",", "\[IndentingNewLine]", 
       RowBox[{"MaxIterations", "->", "1000"}], ",", 
       RowBox[{"PrecisionGoal", "->", "Infinity"}]}], "]"}]}], ";"}], 
   RowBox[{"(*", " ", 
    RowBox[{
    "fitting", " ", "the", " ", "simulated", " ", "trace", " ", "with", " ", 
     "the", " ", "exponential", " ", "model"}], " ", "*)"}], "\[IndentingNewLine]", 
   RowBox[{"expParams", "=", 
    RowBox[{"expFit", "[", "\"\<BestFitParameters\>\"", "]"}]}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"T", "=", 
     RowBox[{"\[Tau]", "/.", "expParams"}]}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"PfHannesschlaeger", "[", 
      RowBox[{"iT_", ",", "cout_", ",", "cin_", ",", "r0_"}], "]"}], ":=", 
     RowBox[{
      RowBox[{"r0", "/", 
       RowBox[{"(", 
        RowBox[{"3", "*", "VW", "*", "iT"}], ")"}]}], "*", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"cin", "+", "cout"}], ")"}], "/", 
       RowBox[{"(", 
        RowBox[{"2", "*", 
         RowBox[{"cout", "^", "2"}]}], ")"}]}]}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{"\"\<\!\(\*SubscriptBox[\(P\), \(f\)]\) from exponential fit with \
Hannesschl\[ADoubleDot]ger correction: \>\"", "<>", 
    RowBox[{"ToString", "[", 
     RowBox[{"NumberForm", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"PfHannesschlaeger", "[", 
         RowBox[{"T", ",", "COUT", ",", "CIN", ",", 
          RowBox[{"DV", "/", "2"}]}], "]"}], "*", "1.*^6"}], ",", 
       RowBox[{"{", 
        RowBox[{"10", ",", "2"}], "}"}]}], "]"}], "]"}], 
    "<>", "\"\< \[Micro]m/s\>\""}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"Show", "[", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"ListPlot", "[", 
        RowBox[{"Vt", ",", "\[IndentingNewLine]", 
         RowBox[{"FrameLabel", "->", 
          RowBox[{"{", 
           RowBox[{"\"\<time (s)\>\"", ",", "\"\<volume (pL)\>\""}], "}"}]}], 
         ",", 
         RowBox[{"PlotStyle", "->", "Black"}], ",", "STYLE"}], "]"}], ",", 
       "\[IndentingNewLine]", 
       RowBox[{"Plot", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"expFit", "[", "\"\<Function\>\"", "]"}], "[", "t", "]"}], ",", 
         RowBox[{"{", 
          RowBox[{"t", ",", 
           RowBox[{"time", "[", 
            RowBox[{"[", "1", "]"}], "]"}], ",", 
           RowBox[{"time", "[", 
            RowBox[{"[", 
             RowBox[{"-", "1"}], "]"}], "]"}]}], "}"}], ",", 
         "\[IndentingNewLine]", 
         RowBox[{"PlotStyle", "->", 
          RowBox[{"Directive", "[", 
           RowBox[{"Red", ",", 
            RowBox[{"Opacity", "[", "0.5", "]"}]}], "]"}]}]}], "]"}], ",", 
       "STYLE"}], "]"}], ",", "\[IndentingNewLine]", 
     RowBox[{"Grid", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"\"\<profiles\>\"", ",", "FILE"}], "}"}], ",", 
         "\[IndentingNewLine]", 
         RowBox[{"{", 
          RowBox[{"\"\<factor (\[Micro]m/px)\>\"", ",", 
           RowBox[{"FACTOR", "*", "1*^6"}]}], "}"}], ",", 
         "\[IndentingNewLine]", 
         RowBox[{"{", 
          RowBox[{"\"\<frames per second\>\"", ",", "FPS"}], "}"}], ",", 
         "\[IndentingNewLine]", 
         RowBox[{"{", 
          RowBox[{"\"\<aspirated GUV diameter (\[Micro]m)\>\"", ",", 
           RowBox[{"DV", "*", "1*^6"}]}], "}"}], ",", "\[IndentingNewLine]", 
         RowBox[{"{", 
          RowBox[{"\"\<pipette diameter (\[Micro]m)\>\"", ",", 
           RowBox[{"DP", "\.08", "*", "1*^6"}]}], "}"}], ",", 
         "\[IndentingNewLine]", 
         RowBox[{"{", 
          RowBox[{"\"\<cin at t=0 (mM)\>\"", ",", "CIN"}], "}"}], ",", 
         "\[IndentingNewLine]", 
         RowBox[{"{", 
          RowBox[{"\"\<cout (mM)\>\"", ",", "COUT"}], "}"}], ",", 
         "\[IndentingNewLine]", 
         RowBox[{"{", 
          
          RowBox[{"\"\<\!\(\*SubscriptBox[\(P\), \(f\)]\) acc. Hannesschl\
\[ADoubleDot]ger (\[Micro]m/s}\>\"", ",", 
           RowBox[{"NumberForm", "[", 
            RowBox[{
             RowBox[{
              RowBox[{"PfHannesschlaeger", "[", 
               RowBox[{"T", ",", "COUT", ",", "CIN", ",", 
                RowBox[{"DV", "/", "2"}]}], "]"}], "*", "1.*^6"}], ",", 
             RowBox[{"{", 
              RowBox[{"10", ",", "2"}], "}"}]}], "]"}]}], "}"}]}], "}"}], ",",
        "\[IndentingNewLine]", 
       RowBox[{"Frame", "->", "All"}]}], "]"}]}], "}"}]}]}]], "Input",
