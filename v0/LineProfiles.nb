Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{"analysis", " ", "parameters", " ", "to", " ", "be", " ", "set"}], 
   "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"T0", "=", "21"}], ";"}], 
   RowBox[{"(*", 
    RowBox[{"time", " ", 
     RowBox[{"(", 
      RowBox[{"in", " ", "s"}], ")"}], " ", "at", " ", "the", " ", "onset", " ",
      "of", " ", 
     RowBox[{"perfusion", "/", "volume"}], " ", "change"}], "*)"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{"volume", " ", "calculation", " ", 
      RowBox[{"acc", ".", " ", "Appendix"}], " ", "in", " ", "Olbrich"}], ",",
      " ", "Rawicz", ",", " ", "Needham", ",", " ", "Evans", ",", 
     RowBox[{
     "Water", " ", "permeability", " ", "and", " ", "mechanical", " ", 
      "strength", " ", "of", " ", "polyunsaturated", " ", "lipid", " ", 
      RowBox[{"bilayers", ".", " ", "Biophys"}], " ", 
      RowBox[{"J", ".", " ", "79"}]}], ",", " ", "321", "\[Dash]", 
     RowBox[{"327", " ", 
      RowBox[{
       RowBox[{"(", "2000", ")"}], "."}]}]}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"ClearAll", "[", 
     RowBox[{
     "Lp", ",", "Acap", ",", "Acyl", ",", "Vcap", ",", "Vcyl", ",", "u", ",", 
      "Aves", ",", "Vves", ",", "A", ",", "A0", ",", "\[ScriptCapitalD]v", ",",
       "V"}], "]"}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
    "hemispherical", " ", "cap", " ", "and", " ", "cylindrical", " ", 
     "portion", " ", "of", " ", "the", " ", "projection", " ", "inside", " ", 
     "the", " ", "pipette"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Acap", "=", 
     RowBox[{"Pi", "*", 
      RowBox[{
       RowBox[{"DP", "^", "2"}], "/", "2"}]}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Acyl", "=", 
     RowBox[{"Pi", "*", "DP", "*", 
      RowBox[{"(", 
       RowBox[{"Lp", "-", 
        RowBox[{"DP", "/", "2"}]}], ")"}]}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Vcap", "=", 
     RowBox[{"Pi", "*", 
      RowBox[{
       RowBox[{"DP", "^", "3"}], "/", "12"}]}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Vcyl", "=", 
     RowBox[{"Pi", "*", 
      RowBox[{"DP", "^", "2"}], "*", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"Lp", "-", 
         RowBox[{"DP", "/", "2"}]}], ")"}], "/", "4"}]}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
    "spherical", " ", "segment", " ", "of", " ", "the", " ", "vesicle", " ", 
     "region", " ", "outside", " ", "the", " ", "pipette"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"u", "=", 
     RowBox[{"Sqrt", "[", 
      RowBox[{"(", 
       RowBox[{"1", "-", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{"DP", "/", "\[ScriptCapitalD]v"}], ")"}], "^", "2"}]}], 
       ")"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Aves", "=", 
     RowBox[{"Pi", "*", 
      RowBox[{"\[ScriptCapitalD]v", "^", "2"}], "*", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"1", "+", "u"}], ")"}], "/", "2"}]}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Vves", "=", 
     RowBox[{"Pi", "*", 
      RowBox[{"\[ScriptCapitalD]v", "^", "3"}], "*", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"2", "+", 
         RowBox[{"3", "u"}], "-", 
         RowBox[{"u", "^", "3"}]}], ")"}], "/", "24"}]}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
    "total", " ", "area", " ", "and", " ", "area", " ", "geometric", " ", 
     "constraint"}], "*)"}], "\n", 
   RowBox[{
    RowBox[{"A", "=", 
     RowBox[{"Acap", "+", "Acyl", "+", "Aves"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"A0", "=", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"Acap", "+", "Aves"}], ")"}], "/.", 
      RowBox[{"(", 
       RowBox[{"\[ScriptCapitalD]v", "->", "DV"}], ")"}]}]}], ";"}], 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{
      RowBox[{"ASSUMPTION", ":", " ", 
       RowBox[{"since", " ", "Lp"}]}], "=", 
      RowBox[{
       RowBox[{
        RowBox[{"DP", "/", "2"}], " ", "is", " ", "assumed", " ", "at", " ", 
        "t"}], "=", "0"}]}], ",", " ", 
     RowBox[{
     "the", " ", "initial", " ", "cylindrical", " ", "area", " ", "is", " ", 
      "exactly", " ", "0"}]}], "*)"}], "\[IndentingNewLine]", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{"expression", " ", "for", " ", "\[ScriptCapitalD]v", " ", 
      RowBox[{"(", 
       RowBox[{
       "vesicle", " ", "diameter", " ", "as", " ", "a", " ", "function", " ", 
        "of", " ", "protreusion", " ", "length", " ", "assuming", " ", 
        "constant", " ", "area", " ", "constraint"}], ")"}]}], ";", " ", 
     RowBox[{
      RowBox[{
      "it", " ", "is", " ", "obtained", " ", "as", " ", "the", " ", "second", 
       " ", "output", " ", 
       RowBox[{"(", "root", ")"}], " ", "of", " ", 
       RowBox[{"Solve", "[", 
        RowBox[{
         RowBox[{"A0", "==", "A"}], ",", "\[ScriptCapitalD]v"}], "]"}]}], "//", 
      RowBox[{"FullSimplify", " ", 
