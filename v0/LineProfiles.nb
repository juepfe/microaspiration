Cell[BoxData[{
 RowBox[{
  RowBox[{"Clear", "[", 
   RowBox[{"A", ",", "V0", ",", "V", ",", "VW"}], "]"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"eqD", "=", 
  RowBox[{
   RowBox[{"D", "[", 
    RowBox[{
     RowBox[{"V", "[", "t", "]"}], ",", "t"}], "]"}], "==", 
   RowBox[{"Pf", "*", "A", "*", "VW", "*", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"cin", "*", 
       RowBox[{"V0", "/", 
        RowBox[{"V", "[", "t", "]"}]}]}], "-", "cout"}], ")"}]}]}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
